    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: backtest (HiddenDivergence XAUUSD H1)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backtest.py",
            "args": [
                "--strategy", "HiddenDivergence",
                "--symbol", "XAUUSD",
                "--tf", "H1"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": true,
            "python": "/opt/anaconda3/envs/trading-system/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },{
            "name": "Debug: backtest (SonicR XAUUSD H1)",
